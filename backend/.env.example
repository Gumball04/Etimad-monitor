APP_NAME=Etimad Tender Monitor
APP_ENV=development
API_PREFIX=/api
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173,http://0.0.0.0:5173
DATABASE_URL=postgresql+psycopg://postgres:123@db:5432/etimad
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=change_me
SMTP_FROM=alerts@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_SSL_PORT=465
SMTP_SSL_FALLBACK=true
SMTP_TIMEOUT_SECONDS=30
FIXED_EMAIL_RECIPIENT=alerts@example.com
EMAIL_COPY_FIXED_RECIPIENT=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000
PLAYWRIGHT_MAX_PAGES=10
PLAYWRIGHT_PAGE_SIZE=6
PLAYWRIGHT_CONCURRENCY=3
PLAYWRIGHT_USER_DATA_DIR=/tmp/etimad-profile
EXPORT_DIR=exports
LOG_LEVEL=INFO
